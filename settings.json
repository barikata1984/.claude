{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "defaultMode": "auto",
    "additionalDirectories": [
      "~/.claude",
      "~/workspace/dotfiles",
      "~/.config/Code/User",
      "/tmp",
      "/opt/ros/one/lib/python3/dist-packages/baldor"
    ],
    "_allow": [
      "Bash(*)",
      "WebSearch",
      "WebFetch",
      "Read",
      "Read(~/**)",
      "Read(//tmp/**)",
      "Edit(~/.claude/skills/**)",
      "Write(~/.claude/skills/**)",
      "Read(//opt/ros/one/lib/python3/dist-packages/baldor/**)",
      "Bash(set -e)",
      "Bash(git revert *)",
      "Bash(pixi install *)",
      "Bash(bash /workspace/scripts/setup.sh)"
    ],
    "_deny": [
      "Bash(rm -rf /:*)",
      "Bash(rm -rf ~:*)",
      "Bash(doppler secrets get:*)",
      "Bash(pass show:*)",
      "Bash(gpg -d:*)",
      "Bash(gpg --decrypt:*)",
      "Bash(op item get:*)",
      "Bash(vault kv get:*)",
      "Bash(aws secretsmanager get-secret-value:*)",
      "Bash(gcloud secrets versions access:*)",
      "Bash(printenv:*)",
      "Bash(printenv)",
      "Bash(cat .env)",
      "Bash(cat .env.local)",
      "Bash(cat .env.secrets)",
      "Bash(cat ~/.netrc)",
      "Bash(cat ~/.aws/credentials)",
      "Bash(cat ~/.ssh/id_rsa)",
      "Bash(cat ~/.ssh/id_ed25519)",
      "Bash(cat ~/.ssh/id_ecdsa)",
      "Bash(cat ~/.ssh/id_dsa)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/.envrc)",
      "Read(**/id_rsa)",
      "Read(**/id_ed25519)",
      "Read(**/id_ecdsa)",
      "Read(**/id_dsa)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*.p12)",
      "Read(**/*.pfx)",
      "Read(**/*.ppk)",
      "Read(**/*.jks)",
      "Read(**/service_account*.json)",
      "Read(**/application_default_credentials.json)",
      "Read(~/.aws/credentials)",
      "Read(~/.kube/config)",
      "Read(~/.docker/config.json)",
      "Read(~/.netrc)",
      "Read(~/.npmrc)",
      "Read(~/.pypirc)",
      "Read(**/secrets.yaml)",
      "Read(**/secrets.yml)",
      "Read(**/secrets.json)",
      "Read(**/*.secret)"
    ],
    "_ask": [
      "Bash(rm:*)",
      "Bash(rmdir:*)",
      "Bash(unlink:*)",
      "Bash(shred:*)",
      "Bash(truncate:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git push --delete:*)",
      "Bash(git checkout --:*)",
      "Bash(git restore:*)",
      "Bash(git rebase:*)",
      "Bash(git commit --amend:*)",
      "Bash(git filter-branch:*)",
      "Bash(git filter-repo:*)",
      "Bash(git branch -D:*)",
      "Bash(git branch -d:*)",
      "Bash(git stash drop:*)",
      "Bash(git stash clear:*)",
      "Bash(git worktree remove:*)",
      "Bash(dd:*)",
      "Bash(mkfs:*)",
      "Bash(shutdown:*)",
      "Bash(reboot:*)",
      "Bash(systemctl stop:*)",
      "Bash(systemctl disable:*)",
      "Bash(systemctl mask:*)",
      "Bash(kill -9:*)",
      "Bash(killall:*)",
      "Bash(apt remove:*)",
      "Bash(apt purge:*)",
      "Bash(apt autoremove:*)",
      "Bash(apt-get remove:*)",
      "Bash(apt-get purge:*)",
      "Bash(apt-get autoremove:*)",
      "Bash(sudo apt remove:*)",
      "Bash(sudo apt purge:*)",
      "Bash(sudo apt autoremove:*)",
      "Bash(sudo apt-get remove:*)",
      "Bash(sudo apt-get purge:*)",
      "Bash(sudo apt-get autoremove:*)",
      "Bash(pip uninstall:*)",
      "Bash(uv pip uninstall:*)",
      "Bash(pixi remove:*)",
      "Bash(pixi global uninstall:*)",
      "Bash(conda remove:*)",
      "Bash(conda uninstall:*)",
      "Bash(cargo uninstall:*)",
      "Bash(sudo docker rm:*)",
      "Bash(sudo docker rmi:*)",
      "Bash(sudo docker volume rm:*)",
      "Bash(sudo docker volume prune:*)",
      "Bash(sudo docker system prune:*)",
      "Bash(sudo docker image prune:*)",
      "Bash(sudo docker container prune:*)",
      "Bash(sudo docker network rm:*)",
      "Bash(sudo docker network prune:*)"
    ]
  },
  "model": "claude-opus-4-6[1M]",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/search-first-reminder.sh"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/search-first-reminder-subagent.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/format-python.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/validate-references.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/format-ja-typography.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/check_proposal.py"
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/check_proposal.py"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "skill-creator@claude-plugins-official": true,
    "andrej-karpathy-skills@karpathy-skills": true
  },
  "extraKnownMarketplaces": {
    "anthropic-agent-skills": {
      "source": {
        "source": "github",
        "repo": "anthropics/skills"
      }
    },
    "karpathy-skills": {
      "source": {
        "source": "github",
        "repo": "multica-ai/andrej-karpathy-skills"
      }
    },
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    }
  },
    "language": "Japanese",
  "effortLevel": "high",
  "tui": "fullscreen",
  "voice": {
    "enabled": false,
    "mode": "tap"
  },
  "autoMemoryEnabled": false,
  "skipWorkflowUsageWarning": true,
  "theme": "auto",
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": false
}
