{
  "permissions": {
    "allow": [
      "Bash(*)",
      "WebSearch",
      "WebFetch",
      "Read(~/**)",
      "Read(//tmp/**)",
      "Edit(~/.claude/skills/**)",
      "Write(~/.claude/skills/**)",
      "Read(//opt/ros/one/lib/python3/dist-packages/baldor/**)"
    ],
    "deny": [
      "Bash(rm -rf /:*)",
      "Bash(rm -rf ~:*)"
    ],
    "ask": [
      "Bash(rm:*)",
      "Bash(rmdir:*)",
      "Bash(unlink:*)",
      "Bash(shred:*)",
      "Bash(truncate:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git push --delete:*)",
      "Bash(git checkout --:*)",
      "Bash(git restore:*)",
      "Bash(git rebase:*)",
      "Bash(git commit --amend:*)",
      "Bash(git filter-branch:*)",
      "Bash(git filter-repo:*)",
      "Bash(git branch -D:*)",
      "Bash(git branch -d:*)",
      "Bash(git stash drop:*)",
      "Bash(git stash clear:*)",
      "Bash(git worktree remove:*)",
      "Bash(dd:*)",
      "Bash(mkfs:*)",
      "Bash(shutdown:*)",
      "Bash(reboot:*)",
      "Bash(systemctl stop:*)",
      "Bash(systemctl disable:*)",
      "Bash(systemctl mask:*)",
      "Bash(kill -9:*)",
      "Bash(killall:*)",
      "Bash(apt remove:*)",
      "Bash(apt purge:*)",
      "Bash(apt autoremove:*)",
      "Bash(apt-get remove:*)",
      "Bash(apt-get purge:*)",
      "Bash(apt-get autoremove:*)",
      "Bash(sudo apt remove:*)",
      "Bash(sudo apt purge:*)",
      "Bash(sudo apt autoremove:*)",
      "Bash(sudo apt-get remove:*)",
      "Bash(sudo apt-get purge:*)",
      "Bash(sudo apt-get autoremove:*)",
      "Bash(pip uninstall:*)",
      "Bash(uv pip uninstall:*)",
      "Bash(pixi remove:*)",
      "Bash(pixi global uninstall:*)",
      "Bash(conda remove:*)",
      "Bash(conda uninstall:*)",
      "Bash(cargo uninstall:*)",
      "Bash(sudo docker rm:*)",
      "Bash(sudo docker rmi:*)",
      "Bash(sudo docker volume rm:*)",
      "Bash(sudo docker volume prune:*)",
      "Bash(sudo docker system prune:*)",
      "Bash(sudo docker image prune:*)",
      "Bash(sudo docker container prune:*)",
      "Bash(sudo docker network rm:*)",
      "Bash(sudo docker network prune:*)"
    ],
    "additionalDirectories": [
      "~/.claude",
      "~/workspace/dotfiles",
      "~/.config/Code/User",
      "/tmp",
      "/opt/ros/one/lib/python3/dist-packages/baldor"
    ],
    "defaultMode": "auto"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/format-python.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/validate-references.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "skill-creator@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "anthropic-agent-skills": {
      "source": {
        "source": "github",
        "repo": "anthropics/skills"
      }
    }
  },
  "autoMemoryEnabled": false,
  "effortLevel": "xhigh",
  "model": "opusplan"
}
