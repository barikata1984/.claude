{
  "permissions": {
    "allow": [
      "Bash(*)",
      "WebSearch",
      "WebFetch",
      "Read(~/.claude/**)",
      "Read(//tmp/**)",
      "Edit(~/.claude/skills/**)",
      "Write(~/.claude/skills/**)",
      "Skill(update-config)",
      "Skill(update-config:*)",
      "Read(~/workspace/dotfiles/**)",
      "Read(~/.config/Code/User/**)",
      "Edit(~/.claude/skills/project-team/**)"
    ],
    "deny": [
      "Bash(rm -rf /:*)",
      "Bash(rm -rf ~:*)"
    ],
    "ask": [
      "Bash(rm:*)",
      "Bash(rmdir:*)",
      "Bash(unlink:*)",
      "Bash(shred:*)",
      "Bash(truncate:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean:*)",
      "Bash(git push --force:*)",
      "Bash(git checkout --:*)",
      "Bash(git restore:*)"
    ],
    "additionalDirectories": [
      "~/.claude/skills/literature-survey",
      "~/workspace/dotfiles",
      "~/.config/Code/User"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/format-python.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/validate-references.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "skill-creator@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "anthropic-agent-skills": {
      "source": {
        "source": "github",
        "repo": "anthropics/skills"
      }
    }
  }
}
